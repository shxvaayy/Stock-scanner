# ═══════════════════════════════════════════
# AutoTheta — Environment Variables
# ═══════════════════════════════════════════
# Copy this to .env and fill in your values.
# Strategy parameters are in config/config.yaml

# ===== Angel One SmartAPI Credentials =====
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=D12345
ANGEL_PASSWORD=1234
ANGEL_TOTP_SECRET=BASE32SECRETFROMANGEL

# IMPORTANT: Register your static IP at smartapi.angelone.in
# → My Profile → My APIs (mandatory from April 1, 2026)
